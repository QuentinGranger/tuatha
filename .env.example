# ─── Tuatha Pro — Environment Variables ───
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
#
# Quick start:
#   1. cp .env.example .env
#   2. Fill in DATABASE_URL, ENCRYPTION_KEY, RESEND_API_KEY (minimum required)
#   3. npm install && npx prisma migrate deploy && npm run dev

# ═══════════════════════════════════════════
# REQUIRED — The app will not start without these
# ═══════════════════════════════════════════

# ── Database ──
DATABASE_URL="postgresql://user:password@localhost:5432/tuatha_pro"
# Production: add ?sslmode=require to enforce TLS

# ── Encryption ──
# AES-256 key for field-level encryption at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ── Email — Resend ──
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Tuatha Pro <noreply@tuatha-app.com>"

# ═══════════════════════════════════════════
# OPTIONAL — Features degrade gracefully without these
# ═══════════════════════════════════════════

# ── App ──
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── Admin API ──
# Bearer token for /api/admin/* endpoints (backup, soft-delete, data-minimization, continuity).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=""

# ── AI — OpenAI (document verification) ──
OPENAI_API_KEY=""

# ── Maps — Google ──
GOOGLE_MAPS_API_KEY=""

# ── Auth — Google OAuth ──
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# ── Auth — Microsoft Outlook OAuth ──
OUTLOOK_CLIENT_ID=""
OUTLOOK_CLIENT_SECRET=""
OUTLOOK_REDIRECT_URI="http://localhost:3000/api/auth/outlook/callback"

# ── Calendar — Calendly OAuth ──
CALENDLY_CLIENT_ID=""
CALENDLY_CLIENT_SECRET=""
CALENDLY_REDIRECT_URI="http://localhost:3000/api/auth/calendly/callback"

# ── WebAuthn / Passkeys ──
WEBAUTHN_RP_ID="localhost"

# ── Web Push Notifications (VAPID) ──
# Generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# ── Visio — TURN Server (WebRTC relay) ──
# Required for video calls behind NAT/VPN/firewalls.
#
# Option 1 (recommended): Metered.ca ephemeral credentials
# Sign up at metered.ca, create an app named "tuatha", copy the API key.
# The server fetches short-lived TURN credentials automatically.
METERED_API_KEY=""
#
# Option 2: Static TURN credentials (Twilio, Xirsys, self-hosted Coturn, etc.)
TURN_SERVER_URL=""
TURN_USERNAME=""
TURN_CREDENTIAL=""

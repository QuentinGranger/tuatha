// ─── Vidéos athlètes (coach) ───

model AthleteVideo {
  id              String        @id @default(uuid())
  filename        String
  originalName    String
  mimeType        String
  size            Int
  filePath        String
  note            String?
  uploadToken     String        @unique
  viewed          Boolean       @default(false)

  athleteId       String
  athlete         Athlete       @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  professionnelId String
  professionnel   Professionnel @relation(fields: [professionnelId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())

  // Soft-delete
  deletedAt       DateTime?
  deletedBy       String?
}

// ─── Documents partagés ───

model SharedDocument {
  id              String        @id @default(uuid())
  filename        String
  originalName    String
  mimeType        String
  size            Int
  filePath        String
  category        String        @default("autre")
  note            String?

  // Sender (always a pro)
  senderProId     String
  senderPro       Professionnel @relation("DocSender", fields: [senderProId], references: [id], onDelete: Cascade)

  // Receiver: either a pro or an athlete (one must be set)
  receiverProId   String?
  receiverPro     Professionnel? @relation("DocReceiver", fields: [receiverProId], references: [id], onDelete: Cascade)
  receiverAthleteId String?
  receiverAthlete Athlete?      @relation(fields: [receiverAthleteId], references: [id], onDelete: Cascade)

  // Optional athlete context for pro-to-pro docs
  athleteId       String?
  athlete         Athlete?      @relation("DocAthleteContext", fields: [athleteId], references: [id], onDelete: SetNull)

  readAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now()) @updatedAt

  // Versioning
  currentVersion  Int           @default(1)
  versions        DocumentVersion[]

  // Soft-delete
  deletedAt       DateTime?
  deletedBy       String?
}

// ─── Document Versioning ───

model DocumentVersion {
  id              String         @id @default(uuid())
  version         Int
  filename        String
  originalName    String
  mimeType        String
  size            Int
  filePath        String
  note            String?

  // Who uploaded this version
  uploadedById    String
  uploadedBy      Professionnel  @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  // Parent document
  documentId      String
  document        SharedDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdAt       DateTime       @default(now())

  @@index([documentId, version])
}

// ─── Documents partagés par l'athlète ───

model AthleteDocument {
  id              String        @id @default(uuid())
  filename        String
  originalName    String
  mimeType        String
  size            Int
  filePath        String
  category        String        @default("autre")
  note            String?

  athleteUserId   String
  athleteUser     AthleteUser   @relation(fields: [athleteUserId], references: [id], onDelete: Cascade)

  // Athlete record linked to this pro (for pro-side queries)
  athleteId       String?
  athlete         Athlete?      @relation("AthleteDocSender", fields: [athleteId], references: [id], onDelete: SetNull)

  professionnelId String
  professionnel   Professionnel @relation("AthleteDocReceiver", fields: [professionnelId], references: [id], onDelete: Cascade)

  readAt          DateTime?
  createdAt       DateTime      @default(now())
  deletedAt       DateTime?

  @@index([athleteUserId, professionnelId])
}


  signatureData   String?
  athleteId       String
  athlete         Athlete       @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  proId           String
  professionnel   Professionnel @relation(fields: [proId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Soft-delete
  deletedAt       DateTime?
  deletedBy       String?
}

// ─── Médecin: Prescriptions (non-ordonnance) ───

model MedPrescription {
  id              String        @id @default(uuid())
  type            String        // activite, douleur, suivi, education, sport, symptomes
  title           String
  contentJson     String        // JSON array of structured lines
  dateStart       DateTime
  dateEnd         DateTime?
  redFlags        String[]      @default([])
  visiblePatient  Boolean       @default(true)
  linkedProtocolId String?
  status          String        @default("active") // active, completed, cancelled
  athleteId       String
  athlete         Athlete       @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  proId           String
  professionnel   Professionnel @relation(fields: [proId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ─── Médecin: Protocoles (parcours par phases) ───

model MedProtocol {
  id              String        @id @default(uuid())
  name            String
  description     String?
  objectives      String[]      @default([])
  phasesJson      String        // JSON array of phases
  linkedTemplates String[]      @default([])
  status          String        @default("draft") // draft, active, completed
  athleteId       String
  athlete         Athlete       @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  proId           String
  professionnel   Professionnel @relation(fields: [proId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Soft-delete
  deletedAt       DateTime?
  deletedBy       String?
}

// ─── Médecin: Alertes médicales ───

model MedAlert {
  id              String        @id @default(uuid())
  severity        String        @default("info") // info, warning, critical
  status          String        @default("open") // open, treated, closed
  source          String        @default("pro")  // patient, capteur, auto, pro
  title           String
  description     String
  context         String?
  commentMedecin  String?
  athleteId       String
  athlete         Athlete       @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  proId           String
  professionnel   Professionnel @relation(fields: [proId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ─── Médecin: Notes cliniques ───

model MedClinicalNote {
  id              String        @id @default(uuid())
  focus           String        // Consultation, Sommeil, Douleurs, etc.
  notePro         String        // Note professionnelle (privée)
  notePatient     String?       // Note visible par le patient
  athleteId       String
  athlete         Athlete       @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  proId           String
  professionnel   Professionnel @relation(fields: [proId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
}

// ─── Médecin: Plan de soins ───

model MedPlan {
  id              String        @id @default(uuid())
  episode         String        @default("Suivi général")
  patientStatus   String        @default("stable") // stable, surveiller, alerte
  conduiteJson    String        @default("[]")  // JSON array of strings
  restrictionsJson String       @default("[]")  // JSON array of strings
  nextStepsJson   String        @default("[]")  // JSON array of {label, status}
  athleteId       String
  athlete         Athlete       @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  proId           String
  professionnel   Professionnel @relation(fields: [proId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ─── Médecin: Signaux vitaux / relevés ───

model MedVitalEntry {
  id              String        @id @default(uuid())
  vitalKey        String        // douleur, fatigue, sommeil, poids, fc, ta_sys, ta_dia, spo2, temperature
  value           Float
  unit            String
  note            String?
  athleteId       String
  athlete         Athlete       @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  proId           String
  professionnel   Professionnel @relation(fields: [proId], references: [id], onDelete: Cascade)
  recordedAt      DateTime      @default(now())
  createdAt       DateTime      @default(now())
}

// ─── Cabinet / Box (équipe professionnelle) ───

enum CabinetRole {
  admin
  member
}

model Cabinet {
  id              String          @id @default(uuid())
  name            String
  address         String?
  ownerId         String
  owner           Professionnel   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members         CabinetMember[]
  adminLogs       AdminLog[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Soft-delete
  deletedAt       DateTime?
  deletedBy       String?
}

model CabinetMember {
  id              String        @id @default(uuid())
  cabinetId       String
  cabinet         Cabinet       @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  proId           String
  professionnel   Professionnel @relation(fields: [proId], references: [id], onDelete: Cascade)
  role            CabinetRole   @default(member)
  joinedAt        DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([cabinetId, proId])
}

model AdminLog {
  id              String        @id @default(uuid())
  cabinetId       String
  cabinet         Cabinet       @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  actorProId      String
  actorPro        Professionnel @relation(fields: [actorProId], references: [id], onDelete: Cascade)
  action          String        // member_added, member_removed, role_changed, cabinet_updated, cabinet_created, offboarding, rights_changed
  targetProId     String?       // the pro affected by the action (if applicable)
  details         Json?         // structured details: { oldRole, newRole, email, sessionsRevoked, ... }
  ip              String?
  createdAt       DateTime      @default(now())
}

model SupportTicket {
  id              String          @id @default(uuid())
  subject         String
  description     String
  category        String          // security, payment, pro, technical, account, investigation, other
  priority        String          @default("normal") // low, normal, high, urgent
  status          String          @default("open")   // open, in_progress, blocked, resolved, closed
  createdById     String?         // athleteUser or pro who created it
  createdByRole   String?         // athlete | pro | admin | system
  assignedToId    String?         // admin who handles it
  resolution      String?         // notes when resolved
  resolvedAt      DateTime?
  blockedReason   String?         // why blocked if status=blocked

  // Relations (nullable — one of the two)
  professionnelId String?
  professionnel   Professionnel?  @relation("ProTickets", fields: [professionnelId], references: [id], onDelete: SetNull)
  athleteUserId   String?
  athleteUser     AthleteUser?    @relation("AthleteTickets", fields: [athleteUserId], references: [id], onDelete: SetNull)

  // Link to investigation (if this ticket was created by an investigation)
  investigationId String?
  investigation   Investigation?  @relation(fields: [investigationId], references: [id], onDelete: SetNull)

  comments        TicketComment[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@index([professionnelId])
  @@index([athleteUserId])
}

model TicketComment {
  id              String        @id @default(uuid())
  content         String
  authorRole      String        // admin | system | pro | athlete
  authorId        String?       // id of the author (admin name, pro id, etc.)
  authorName      String?       // display name
  internal        Boolean       @default(false) // internal admin note vs visible to user
  ticketId        String
  ticket          SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
}

// ─── Investigations (compliance, fraud, RGPD) ───

model Investigation {
  id              String          @id @default(uuid())
  title           String
  description     String
  type            String          // compliance, fraud, security, rgpd, other
  severity        String          @default("medium") // low, medium, high, critical
  status          String          @default("open")   // open, in_progress, pending_info, closed_resolved, closed_unfounded
  outcome         String?         // final decision / resolution notes

  // Who is being investigated (one of the two)
  professionnelId String?
  professionnel   Professionnel?  @relation("ProInvestigations", fields: [professionnelId], references: [id], onDelete: SetNull)
  athleteUserId   String?
  athleteUser     AthleteUser?    @relation("AthleteInvestigations", fields: [athleteUserId], references: [id], onDelete: SetNull)

  // Who opened & assigned
  openedBy        String          @default("admin") // admin name or "system"
  assignedTo      String?         // admin who is responsible

  // Actions taken
  actionsTaken    String[]        @default([])       // e.g. ["account_suspended", "sessions_revoked", "dpo_notified"]
  dpoNotifiedAt   DateTime?       // when DPO was notified
  userNotifiedAt  DateTime?       // when the user was notified

  // Timeline
  closedAt        DateTime?
  closedBy        String?

  tickets         SupportTicket[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@index([professionnelId])
  @@index([athleteUserId])
}

// ─── Platform Health & Monitoring ───

model ApiErrorLog {
  id              String        @id @default(uuid())
  endpoint        String
  method          String
  statusCode      Int
  errorMessage    String?
  userId          String?       // who triggered it (if authenticated)
  userRole        String?       // athlete | pro | admin
  ip              String?
  userAgent       String?
  requestDuration Int?          // milliseconds
  createdAt       DateTime      @default(now())
}

model RequestLog {
  id              String        @id @default(uuid())
  endpoint        String
  method          String
  duration        Int           // milliseconds
  statusCode      Int
  userId          String?
  userRole        String?
  ip              String?
  createdAt       DateTime      @default(now())
}

model BackupLog {
  id              String        @id @default(uuid())
  status          String        // success, failed, partial
  type            String        // full, incremental
  sizeBytes       Int?          // backup size
  errorMessage    String?
  startedAt       DateTime
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
}

model EmailLog {
  id              String        @id @default(uuid())
  to              String
  subject         String
  status          String        // sent, delivered, bounced, failed
  providerId      String?       // SendGrid/Mailgun message ID
  errorMessage    String?
  openedAt        DateTime?
  clickedAt       DateTime?
  createdAt       DateTime      @default(now())
}

model HealthCheckLog {
  id              String        @id @default(uuid())
  service         String        // database, stripe, email, storage, hds
  status          String        // healthy, degraded, down
  responseTime    Int?          // ms
  errorMessage    String?
  checkedAt       DateTime      @default(now())
}

model AdminSession {
  id          String   @id @default(uuid())
  token       String   @unique
  email       String
  ip          String?
  userAgent   String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Consultation Prep (mini checklist) ───

model ConsultationPrep {
  id              String        @id @default(uuid())
  calendarEventId String        @unique
  calendarEvent   CalendarEvent @relation(fields: [calendarEventId], references: [id], onDelete: Cascade)
  athleteUserId   String
  athleteUser     AthleteUser   @relation(fields: [athleteUserId], references: [id], onDelete: Cascade)

  motifDetail     String?       // complément du motif
  symptoms        String?       // symptômes décrits
  painLevel       Int?          // 0-10
  fatigueLevel    Int?          // 0-10
  documents       String[]      // file names or paths uploaded
  evolution       String?       // évolution depuis dernière séance
  questionnaire   Json?         // mini questionnaire answers { q: string, a: string }[]

  completedAt     DateTime?     // null = not completed
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([athleteUserId])
}

// ─── Booking Reminders ───

model BookingReminder {
  id              String        @id @default(uuid())
  calendarEventId String
  calendarEvent   CalendarEvent @relation(fields: [calendarEventId], references: [id], onDelete: Cascade)
  athleteUserId   String
  athleteUser     AthleteUser   @relation(fields: [athleteUserId], references: [id], onDelete: Cascade)
  professionnelId String
  professionnel   Professionnel @relation(fields: [professionnelId], references: [id], onDelete: Cascade)

  type            String        // confirmation, j2, j1, h2, h1_visio, now_visio
  recipientType   String        @default("athlete") // "athlete" or "pro"
  scheduledAt     DateTime      // when the reminder should be sent
  sentAt          DateTime?     // null = not sent yet
  channel         String        @default("email") // email, inapp, sms
  dismissed       Boolean       @default(false)

  // Snapshot of event data for the reminder content
  eventTitle      String
  eventDate       DateTime
  eventEndDate    DateTime?
  eventFormat     String        @default("presentiel") // presentiel, teleconsultation
  eventMotif      String
  eventAddress    String?
  eventDocuments  String?       // comma-separated docs to bring
  eventVisioRoomId String?      // visio room ID for teleconsultation reminders

  createdAt       DateTime      @default(now())

  @@index([athleteUserId, sentAt])
  @@index([professionnelId, sentAt])
  @@index([scheduledAt, sentAt])
}

// ─── Waitlist (earlier slot alerts) ───

model WaitlistEntry {
  id              String        @id @default(uuid())
  calendarEventId String
  calendarEvent   CalendarEvent @relation(fields: [calendarEventId], references: [id], onDelete: Cascade)
  athleteUserId   String
  athleteUser     AthleteUser   @relation(fields: [athleteUserId], references: [id], onDelete: Cascade)
  professionnelId String
  professionnel   Professionnel @relation(fields: [professionnelId], references: [id], onDelete: Cascade)

  beforeDate      DateTime      // alert if slot opens before this date
  notifiedAt      DateTime?     // null = not yet notified
  active          Boolean       @default(true)

  createdAt       DateTime      @default(now())

  @@unique([calendarEventId, athleteUserId])
  @@index([professionnelId, active])
}

// ─── Slot Alerts (planning gap optimization) ───

model SlotAlert {
  id              String        @id @default(uuid())
  athleteUserId   String
  athleteUser     AthleteUser   @relation(fields: [athleteUserId], references: [id], onDelete: Cascade)
  professionnelId String?
  professionnel   Professionnel? @relation(fields: [professionnelId], references: [id], onDelete: Cascade)

  preferredDays   Int[]         // 0=dim,1=lun…6=sam
  timeStart       String?       // "08:00"
  timeEnd         String?       // "18:00"
  format          String?       // "presentiel" | "teleconsultation" | null = any
  motif           String?       // motif de consultation original
  priority        Boolean       @default(false) // SMS if priority

  active          Boolean       @default(true)
  notifiedAt      DateTime?     // last notification sent
  matchedSlotDate DateTime?     // slot date that was found
  bookedEventId   String?       // if athlete booked from this alert

  createdAt       DateTime      @default(now())

  @@index([athleteUserId, active])
  @@index([professionnelId, active])
}

// ─── Réglages de confidentialité athlète → par professionnel ───

model AthletePrivacySettings {
  id                  String        @id @default(uuid())
  athleteUserId       String
  athleteUser         AthleteUser   @relation(fields: [athleteUserId], references: [id], onDelete: Cascade)
  professionnelId     String
  professionnel       Professionnel @relation(fields: [professionnelId], references: [id], onDelete: Cascade)

  shareSport          Boolean       @default(true)
  sharePhysical       Boolean       @default(true)
  shareAntecedents    Boolean       @default(false)
  shareTraitements    Boolean       @default(false)
  shareContraindic    Boolean       @default(false)
  shareVitals         Boolean       @default(false)
  shareConsultPrep    Boolean       @default(true)
  sharePhoto          Boolean       @default(true)
  shareMessaging      Boolean       @default(true)
  expiresAt           DateTime?     // Optional access expiration date

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([athleteUserId, professionnelId])
  @@index([athleteUserId])
}

// ─── Demande d'accès pro → données athlète ───

model DataAccessRequest {
  id              String        @id @default(uuid())
  athleteUserId   String
  professionnelId String
  dataKey         String        // "shareAntecedents" | "shareTraitements" | "shareContraindic" | "shareVitals" | "shareMessaging" etc.
  reason          String?       // optional justification from pro
  status          String        @default("pending") // "pending" | "accepted" | "rejected"
  respondedAt     DateTime?
  createdAt       DateTime      @default(now())

  athleteUser     AthleteUser   @relation(fields: [athleteUserId], references: [id], onDelete: Cascade)
  professionnel   Professionnel @relation(fields: [professionnelId], references: [id], onDelete: Cascade)

  @@index([athleteUserId, status])
  @@index([professionnelId, athleteUserId])
}

// ─── Journal d'accès pro → données athlète ───

model ProAccessLog {
  id              String        @id @default(uuid())
  athleteUserId   String
  professionnelId String
  action          String        // "view_profile" | "view_list" | "view_vitals" | "view_messages" | "view_plan_kine" | "view_plan_nutri" | "view_ordonnance" | "view_programme" | "search"
  resource        String?       // optional detail: e.g. "kine_plan:abc123"
  blocked         Boolean       @default(false) // true if access was denied by privacy settings
  createdAt       DateTime      @default(now())

  @@index([athleteUserId, professionnelId, createdAt])
  @@index([athleteUserId, createdAt])
}

// ─── Health App Connections (Direct OAuth: Garmin, Polar, WHOOP, Oura) ───

model HealthAppConnection {
  id              String    @id @default(uuid())
  athleteUserId   String
  athleteUser     AthleteUser @relation(fields: [athleteUserId], references: [id], onDelete: Cascade)
  provider        String    // "GARMIN" | "POLAR" | "WHOOP" | "OURA"
  status          String    @default("pending") // "pending" | "connected" | "disconnected" | "error"
  // OAuth tokens (encrypted at rest via app layer)
  accessToken     String?
  accessTokenSecret String? // Garmin OAuth 1.0a only
  refreshToken    String?   // Polar/WHOOP/Oura OAuth 2.0
  tokenExpiresAt  DateTime? // OAuth 2.0 token expiry
  providerUserId  String?   // Provider's user ID if available
  scopes          String[]  @default([])
  lastSyncAt      DateTime?
  lastSyncError   String?
  metadata        Json?     // Extra provider-specific data
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  dataPoints      HealthDataPoint[]

  @@unique([athleteUserId, provider])
  @@index([athleteUserId])
}

model HealthDataPoint {
  id              String    @id @default(uuid())
  connectionId    String
  connection      HealthAppConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  athleteUserId   String
  category        String    // "steps" | "heart_rate" | "sleep" | "calories" | "distance" | "active_minutes" | "spo2" | "hrv" | "body_weight" | "body_fat"
  value           Float
  unit            String    // "count" | "bpm" | "hours" | "kcal" | "km" | "min" | "%" | "ms" | "kg"
  date            DateTime  // The date this data point refers to
  startTime       DateTime? // For time-range data (e.g. sleep start)
  endTime         DateTime? // For time-range data (e.g. sleep end)
  source          String?   // Original source app name
  metadata        Json?     // Extra data (e.g. sleep stages, HR zones)
  createdAt       DateTime  @default(now())

  @@unique([connectionId, category, date])
  @@index([athleteUserId, category, date])
  @@index([connectionId, date])
}

// ─── Visio Signaling (DB-backed, cross-instance) ───

model VisioSignal {
  id        String   @id @default(uuid())
  roomId    String
  senderId  String
  targetId  String?
  type      String   // join, offer, answer, ice-candidate, leave
  payload   String?  @db.Text // JSON-stringified SDP / ICE candidate
  createdAt DateTime @default(now())

  @@index([roomId, createdAt])
}

// ─── Payments (Stripe Connect + Checkout) ───
// PCI DSS / CNIL : AUCUNE donnée de carte n'est stockée ici.
// Pas de PAN, pas de CVV, pas d'empreinte carte, pas de PaymentMethod ID.
// Seuls les identifiants Stripe nécessaires à la traçabilité comptable sont conservés.
// Voir src/lib/pci.ts pour la politique complète.

model Payment {
  id                    String        @id @default(uuid())
  // Stripe references
  stripeCheckoutSessionId String     @unique
  stripePaymentIntentId   String?    @unique
  // Actors
  athleteUserId         String
  athleteUser           AthleteUser   @relation(fields: [athleteUserId], references: [id], onDelete: Cascade)
  professionnelId       String
  professionnel         Professionnel @relation(fields: [professionnelId], references: [id], onDelete: Cascade)
  calendarEventId       String?
  calendarEvent         CalendarEvent? @relation(fields: [calendarEventId], references: [id], onDelete: SetNull)
  // Amounts (all in cents)
  amount                Int           // total charged to athlete (gross)
  platformFee           Int           @default(0) // Tuatha commission (application_fee_amount)
  stripeFee             Int?          // Stripe processing fee (from balance_transaction)
  netAmount             Int?          // net amount transferred to pro (amount - platformFee)
  refundAmount          Int?          // amount refunded (partial or full), in cents
  currency              String        @default("eur")
  // Status — See src/lib/paymentStatus.ts for full list
  status                String        @default("appointment_created")
  paidAt                DateTime?
  refundedAt            DateTime?
  payoutAt              DateTime?     // when funds arrived at pro's bank account
  // Metadata
  description           String?
  prestationType        String?       // consultation_visio, consultation_presentielle, suivi_ponctuel, pack_non_remboursable
  metadata              String?       @db.Text // JSON for extra info
  // Receipt
  receiptNumber         String?       @unique // e.g. "TUA-2026-000042"
  receiptGeneratedAt    DateTime?
  receiptEmailSentAt    DateTime?

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  invoice               Invoice?

  @@index([athleteUserId])
  @@index([professionnelId])
  @@index([calendarEventId])
  @@index([status])
}

// ─── Suivi alimentaire journalier ───

model NutriDayLog {
  id            String      @id @default(uuid())
  date          DateTime    @db.Date
  athleteUserId String
  athleteUser   AthleteUser @relation(fields: [athleteUserId], references: [id], onDelete: Cascade)
  mealItemId    String
  consumed      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([date, athleteUserId, mealItemId])
  @@index([athleteUserId, date])
}

model NutriCustomEntry {
  id            String      @id @default(uuid())
  date          DateTime    @db.Date
  athleteUserId String
  athleteUser   AthleteUser @relation(fields: [athleteUserId], references: [id], onDelete: Cascade)
  nutriMealId   String
  name          String
  quantity      Float       @default(1)
  unit          String      @default("portion")
  kcal          Int         @default(0)
  protein       Float       @default(0)
  carbs         Float       @default(0)
  fat           Float       @default(0)
  createdAt     DateTime    @default(now())

  @@index([athleteUserId, date])
}

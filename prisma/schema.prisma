// ─── Réseau Professionnel ───

enum ConnectionStatus {
  connecte
  en_attente
  refuse
}

model ProConnection {
  id              String           @id @default(uuid())
  athleteId       String
  athlete         Athlete          @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  ownerProId      String
  ownerPro        Professionnel    @relation("ConnectionOwner", fields: [ownerProId], references: [id], onDelete: Cascade)
  connectedProId  String
  connectedPro    Professionnel    @relation("ConnectionPro", fields: [connectedProId], references: [id], onDelete: Cascade)
  role            String           @default("Autre")
  status          ConnectionStatus @default(en_attente)
  readProgramme   Boolean          @default(false)
  readIndicateurs Boolean          @default(false)
  readBlessures   Boolean          @default(false)
  readDocuments   Boolean          @default(false)
  writeNote       Boolean          @default(false)
  writeProgramme  Boolean          @default(false)
  writeValidation Boolean          @default(false)
  scope           String           @default("partage")
  dataScopes      Json?            // Granular per-category access: { entrainement: "read", imagerie: "none", ... }
  expiresAt       DateTime?        // null = no expiration (owner); set = time-limited shared access
  renewedAt       DateTime?        // last renewal timestamp
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

enum InviteStatus {
  envoyee
  acceptee
  refusee
  annulee
}

model ProInvitation {
  id              String       @id @default(uuid())
  token           String       @unique @default(uuid())
  athleteId       String
  athlete         Athlete      @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  senderProId     String
  senderPro       Professionnel @relation("InviteSender", fields: [senderProId], references: [id], onDelete: Cascade)
  email           String
  role            String       @default("Autre")
  message         String?
  status          InviteStatus @default(envoyee)
  expiresAt       DateTime     @default(now())
  usedAt          DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model CollabNote {
  id              String        @id @default(uuid())
  athleteId       String
  athlete         Athlete       @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  authorProId     String
  authorPro       Professionnel @relation(fields: [authorProId], references: [id], onDelete: Cascade)
  content         String
  type            String        @default("note")
  tags            String[]      @default([])
  pinned          Boolean       @default(false)
  parentId        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Soft-delete
  deletedAt       DateTime?
  deletedBy       String?
}

model ProMessage {
  id              String        @id @default(uuid())
  senderProId     String
  senderPro       Professionnel @relation("MessageSender", fields: [senderProId], references: [id], onDelete: Cascade)
  receiverProId   String
  receiverPro     Professionnel @relation("MessageReceiver", fields: [receiverProId], references: [id], onDelete: Cascade)
  athleteId       String?
  athlete         Athlete?      @relation(fields: [athleteId], references: [id], onDelete: SetNull)
  content         String
  reactions       Json          @default("[]")
  read            Boolean       @default(false)
  pinned          Boolean       @default(false)
  important       Boolean       @default(false)
  replyToId       String?
  conversationId  String?
  conversation    ProConversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  editedAt        DateTime?

  // Attachments
  attachments     ProMessageAttachment[]

  // Soft-delete
  deletedAt       DateTime?
  deletedBy       String?

  @@index([conversationId])
}

model ProMessageAttachment {
  id              String      @id @default(uuid())
  messageId       String
  message         ProMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  filename        String
  originalName    String
  mimeType        String
  size            Int
  filePath        String
  createdAt       DateTime    @default(now())

  @@index([messageId])
}

// ─── Group conversations ───

model ProConversation {
  id          String   @id @default(uuid())
  name        String?
  isGroup     Boolean  @default(false)
  athleteId   String?
  athlete     Athlete? @relation(fields: [athleteId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  createdById String
  createdBy   Professionnel @relation(fields: [createdById], references: [id])
  members     ProConversationMember[]
  messages    ProMessage[]
}

model ProConversationMember {
  id             String          @id @default(uuid())
  conversationId String
  conversation   ProConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  proId          String
  pro            Professionnel   @relation(fields: [proId], references: [id], onDelete: Cascade)
  joinedAt       DateTime        @default(now())
  role           String          @default("member")

  @@unique([conversationId, proId])
}

// ─── Push Subscriptions (Web Push API) ───

model PushSubscription {
  id              String        @id @default(uuid())
  proId           String
  pro             Professionnel @relation(fields: [proId], references: [id], onDelete: Cascade)
  endpoint        String        @unique
  p256dh          String
  auth            String
  userAgent       String?
  createdAt       DateTime      @default(now())

  @@index([proId])
}

// ─── Facturation ───

enum InvoiceStatus {
  unpaid
  paid
  overdue
  cancelled
}

model Invoice {
  id               String        @id @default(uuid())
  number           String
  description      String
  amount           Float
  status           InvoiceStatus @default(unpaid)
  dueDate          DateTime
  paidDate         DateTime?
  paymentMethod    String?
  notes            String?
  // Source: "manual" (créée par le pro) ou "stripe" (auto-générée après paiement Stripe)
  source           String        @default("manual")
  // Lien vers le paiement Stripe (si source = "stripe")
  paymentId        String?       @unique
  payment          Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  // Type de prestation
  prestationType   String?
  // Patient (legacy Athlete fiche pro-side)
  athleteId        String?
  athlete          Athlete?      @relation(fields: [athleteId], references: [id], onDelete: SetNull)
  // Patient (AthleteUser app-side, pour les factures Stripe)
  athleteUserId    String?
  athleteUser      AthleteUser?  @relation(fields: [athleteUserId], references: [id], onDelete: SetNull)
  professionnelId  String
  professionnel    Professionnel @relation(fields: [professionnelId], references: [id], onDelete: Cascade)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Soft-delete
  deletedAt        DateTime?
  deletedBy        String?

  @@index([professionnelId])
  @@index([athleteUserId])
  @@index([status])
}


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Professionnel {
  id                  String          @id @default(uuid())
  nom                 String
  prenom              String
  email               String          @unique
  telephone           String
  specialite          String
  statutExercice      String          @default("liberal") // liberal, salarie, mixte, remplacant, autre
  numeroVerification  String
  documentPath        String?
  avatarPath          String?
  password            String
  emailVerified       Boolean         @default(false)
  emailVerifyToken    String?
  emailVerifyExpires  DateTime?
  accountStatus       String          @default("draft") // draft, stripe_pending, profile_pending, compliance_review, active, suspended, restricted, deleted
  verificationStatus  String          @default("unverified") // unverified, pending, verified, rejected
  verifiedAt          DateTime?
  verificationNote    String?
  totpSecret          String?
  twoFactorEnabled    Boolean         @default(false)
  recoveryCodes       String[]        @default([]) // hashed recovery codes
  adresseCabinet      String?
  searchable          Boolean         @default(true)
  latitude            Float?
  longitude           Float?
  placeId             String?
  // CGU acceptance tracking
  acceptedCguVersion  String?         // e.g. "1.0"
  acceptedCguAt       DateTime?
  acceptedCguIp       String?
  // Stripe Connect
  stripeAccountId           String?       // acct_xxx
  stripeOnboardingComplete  Boolean       @default(false)
  stripeChargesEnabled      Boolean       @default(false)
  stripePayoutsEnabled      Boolean       @default(false)
  stripeDetailsSubmitted    Boolean       @default(false)
  // Remboursement / informations conventionnement
  professionAffichee        String?       // ex: "Médecin du sport", "Kinésithérapeute DE"
  specialiteAffichee        String?       // ex: "Traumatologie sportive", "Rééducation fonctionnelle"
  conventionne              String        @default("a_verifier") // oui, non, secteur_1, secteur_2, a_verifier
  prestationRemboursableType String?      // ex: "Consultation médicale", "Actes de rééducation", "Bilan diététique"
  ordonnanceRequise         String        @default("non") // oui, non, selon_acte
  mutuelleAcceptee          String        @default("a_verifier") // oui, non, a_verifier
  remboursementNote         String?       // note libre du pro sur ses conditions de remboursement
  // CGU Pro acceptance tracking
  acceptedCguProVersion String?       // e.g. "1.0"
  acceptedCguProAt      DateTime?
  acceptedCguProIp      String?

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  services            Service[]
  tarifs              Tarif[]
  disponibilites      Disponibilite[]
  calendriers         CalendrierSync[]
  athletes            Athlete[]
  calendarEvents      CalendarEvent[]
  kanbanTasks         KanbanTask[]
  sessions            Session[]
  exerciseTemplates   ExerciseTemplate[]
  connectionsAsOwner  ProConnection[]  @relation("ConnectionOwner")
  connectionsAsPro    ProConnection[]  @relation("ConnectionPro")
  invitationsSent     ProInvitation[]  @relation("InviteSender")
  collabNotes         CollabNote[]
  payments            Payment[]
  messagesSent        ProMessage[]     @relation("MessageSender")
  messagesReceived    ProMessage[]     @relation("MessageReceiver")
  invoices            Invoice[]
  kinePlans           KinePlan[]
  kineVideos          KineVideo[]
  kineAlerts          KineAlert[]
  kineAlertRules      KineAlertRule[]
  nutriObjectives     NutriObjective[]
  nutriRules          NutriRule[]
  nutriConsultNotes   NutriConsultNote[] @relation("NutriNotesPro")
  nutriPlans          NutriPlan[]
  nutriMealTemplates  NutriMealTemplate[]
  nutriDayTemplates   NutriDayTemplate[]
  docsSent            SharedDocument[] @relation("DocSender")
  docsReceived        SharedDocument[] @relation("DocReceiver")
  athleteVideos       AthleteVideo[]
  medOrdonnances      MedOrdonnance[]
  medPrescriptions    MedPrescription[]
  medProtocols        MedProtocol[]
  medAlerts           MedAlert[]
  medClinicalNotes    MedClinicalNote[]
  medPlans            MedPlan[]
  medVitalEntries     MedVitalEntry[]
  verificationDocs    VerificationDocument[]
  passwordResets      PasswordReset[]
  securityAlerts      SecurityAlert[]
  authSessions        AuthSession[]
  passkeys            Passkey[]
  cabinetsOwned       Cabinet[]
  cabinetMemberships  CabinetMember[]
  adminLogs           AdminLog[]
  documentVersions    DocumentVersion[]
  consentLogs         ConsentLog[]
  subjectRequests     SubjectAccessRequest[]
  groupsCreated       ProConversation[]
  groupMemberships    ProConversationMember[]
  pushSubscriptions   PushSubscription[]
  connectionRequests  ConnectionRequest[]
  blockedAthletes     BlockedAthlete[]
  athleteProMessages  AthleteProMessage[]
  athleteGroupMemberships AthleteGroupMember[]
  bookingReminders    BookingReminder[]
  waitlistEntries     WaitlistEntry[]
  slotAlerts          SlotAlert[]
  athletePrivacySettings AthletePrivacySettings[]
  athleteDocsReceived AthleteDocument[] @relation("AthleteDocReceiver")
  dataAccessRequests  DataAccessRequest[]
  athleteBlockedPros  AthleteBlockedPro[]
  tickets             SupportTicket[]   @relation("ProTickets")
  investigations      Investigation[]   @relation("ProInvestigations")
}

// ─── Compte Athlète (inscription autonome) ───

model AthleteUser {
  id                  String    @id @default(uuid())
  nom                 String
  prenom              String
  email               String    @unique
  telephone           String
  password            String
  sport               String?
  dateNaissance       DateTime?
  taille              Float?
  poids               Float?
  objectif            String?
  antecedents         String[]  @default([])
  traitements         String?
  contreIndications   String?
  avatarPath          String?
  emailVerified       Boolean   @default(false)
  emailVerifyToken    String?
  emailVerifyExpires  DateTime?
  acceptedCguVersion          String?
  acceptedCguAt               DateTime?
  acceptedCguIp               String?
  acceptedPrivacyVersion      String?
  acceptedPrivacyAt           DateTime?
  acceptedHealthCharterVersion String?
  acceptedHealthCharterAt     DateTime?
  consentMarketing            Boolean   @default(false)
  consentMarketingAt          DateTime?
  consentAI                   Boolean   @default(false)
  consentAIAt                 DateTime?
  // MFA / 2FA
  totpSecret          String?
  twoFactorEnabled    Boolean   @default(false)
  recoveryCodes       String[]  @default([]) // hashed recovery codes
  // Admin
  accountStatus       String    @default("active") // active, suspended, restricted, deleted
  suspendedAt         DateTime?
  suspendedReason     String?
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  athleteConsents     AthleteConsent[]
  authSessions        AuthSession[]
  connectionRequests  ConnectionRequest[]
  blockedByPros       BlockedAthlete[]
  blockedPros         AthleteBlockedPro[]
  athleteProMessages  AthleteProMessage[]
  athleteGroups       AthleteGroupConversation[]
  bookingReminders    BookingReminder[]
  consultationPreps   ConsultationPrep[]
  waitlistEntries     WaitlistEntry[]
  slotAlerts          SlotAlert[]
  calendarEvents      CalendarEvent[]
  privacySettings     AthletePrivacySettings[]
  dataAccessRequests  DataAccessRequest[]
  athleteDocsSent     AthleteDocument[]
  healthAppConnections HealthAppConnection[]
  payments            Payment[]
  invoices            Invoice[]
  nutriDayLogs        NutriDayLog[]
  nutriCustomEntries  NutriCustomEntry[]
  athletes            Athlete[]
  accessLogs          AthleteAccessLog[]
  passwordResets      PasswordReset[]
  tickets             SupportTicket[]   @relation("AthleteTickets")
  investigations      Investigation[]   @relation("AthleteInvestigations")
}

// ─── Messages athlète ↔ professionnel ───

model AthleteProMessage {
  id              String        @id @default(uuid())
  athleteUserId   String
  athleteUser     AthleteUser   @relation(fields: [athleteUserId], references: [id], onDelete: Cascade)
  professionnelId String
  professionnel   Professionnel @relation(fields: [professionnelId], references: [id], onDelete: Cascade)
  senderType      String        // "athlete" | "pro"
  content         String
  read            Boolean       @default(false)
  pinned          Boolean       @default(false)
  important       Boolean       @default(false)
  replyToId       String?
  reactions       Json          @default("[]")
  createdAt       DateTime      @default(now())
  editedAt        DateTime?

  attachments     AthleteProMessageAttachment[]

  @@index([athleteUserId, professionnelId])
  @@index([professionnelId])
}

model AthleteProMessageAttachment {
  id           String            @id @default(uuid())
  messageId    String
  message      AthleteProMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  filename     String
  originalName String
  mimeType     String
  size         Int
  filePath     String
  createdAt    DateTime          @default(now())

  @@index([messageId])
}

// ─── Groupes athlète ↔ professionnels ───

model AthleteGroupConversation {
  id            String   @id @default(uuid())
  name          String?
  athleteUserId String
  athleteUser   AthleteUser @relation(fields: [athleteUserId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  members       AthleteGroupMember[]
  messages      AthleteGroupMessage[]
}

model AthleteGroupMember {
  id             String   @id @default(uuid())
  conversationId String
  conversation   AthleteGroupConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  professionnelId String
  professionnel  Professionnel @relation(fields: [professionnelId], references: [id], onDelete: Cascade)
  joinedAt       DateTime @default(now())
  role           String   @default("member")

  @@unique([conversationId, professionnelId])
}

model AthleteGroupMessage {
  id             String   @id @default(uuid())
  conversationId String
  conversation   AthleteGroupConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderType     String   // "athlete" | "pro"
  senderProId    String?
  content        String
  read           Boolean  @default(false)
  pinned         Boolean  @default(false)
  important      Boolean  @default(false)
  replyToId      String?
  reactions      Json     @default("[]")
  createdAt      DateTime @default(now())
  editedAt       DateTime?

  attachments    AthleteGroupMessageAttachment[]

  @@index([conversationId])
}

model AthleteGroupMessageAttachment {
  id           String              @id @default(uuid())
  messageId    String
  message      AthleteGroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  filename     String
  originalName String
  mimeType     String
  size         Int
  filePath     String
  createdAt    DateTime            @default(now())

  @@index([messageId])
}

// ─── Demande de connexion athlète → professionnel ───

model ConnectionRequest {
  id                String   @id @default(uuid())
  athleteUserId     String
  professionnelId   String
  status            String   @default("pending") // pending | accepted | rejected
  requestedBy       String   @default("athlete") // "athlete" | "pro"
  createdAt         DateTime @default(now())
  respondedAt       DateTime?

  athleteUser       AthleteUser   @relation(fields: [athleteUserId], references: [id], onDelete: Cascade)
  professionnel     Professionnel @relation(fields: [professionnelId], references: [id], onDelete: Cascade)

  @@unique([athleteUserId, professionnelId])
  @@index([professionnelId])
}

// ─── Blocage athlète par un pro ───

model BlockedAthlete {
  id              String   @id @default(uuid())
  professionnelId String
  athleteUserId   String
  createdAt       DateTime @default(now())
  reason          String?

  professionnel   Professionnel @relation(fields: [professionnelId], references: [id], onDelete: Cascade)
  athleteUser     AthleteUser   @relation(fields: [athleteUserId], references: [id], onDelete: Cascade)

  @@unique([professionnelId, athleteUserId])
}

// ─── Blocage pro par un athlète ───

model AthleteBlockedPro {
  id              String        @id @default(uuid())
  athleteUserId   String
  professionnelId String
  reason          String?
  createdAt       DateTime      @default(now())

  athleteUser     AthleteUser   @relation(fields: [athleteUserId], references: [id], onDelete: Cascade)
  professionnel   Professionnel @relation(fields: [professionnelId], references: [id], onDelete: Cascade)

  @@unique([athleteUserId, professionnelId])
}

// ─── Droits utilisateur RGPD (Art. 15, 16, 17) ───

model SubjectAccessRequest {
  id              String   @id @default(uuid())

  // Type of right exercised
  rightType       String   // "access" | "rectification" | "erasure" | "portability" | "opposition"

  // Status tracking
  status          String   @default("pending") // "pending" | "processing" | "completed" | "rejected" | "partial"
  reason          String?  // Reason for rejection or additional context

  // Who
  athleteId       String
  athlete         Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  requestedByProId String  // The pro who submitted the request on behalf of the athlete
  requestedByPro  Professionnel @relation(fields: [requestedByProId], references: [id], onDelete: Cascade)

  // What was requested / delivered
  details         String?  // JSON: fields to rectify, categories to export, etc.
  result          String?  // JSON: what was done (fields changed, data exported, etc.)

  // Context
  ip              String?
  userAgent       String?

  // Timestamps
  createdAt       DateTime @default(now())
  processedAt     DateTime?
  completedAt     DateTime?

  @@index([athleteId])
  @@index([requestedByProId])
  @@index([status])
}

model VerificationDocument {
  id               String        @id @default(uuid())
  type             String        // rpps, adeli, carte_pro, diplome, structure, other
  label            String        // Display name e.g. "Diplôme de kinésithérapie"
  filePath         String
  status           String        @default("pending") // pending, accepted, rejected
  note             String?       // Admin note
  aiVerified       Boolean?      // null = not analyzed, true = AI approved, false = AI flagged
  aiConfidence     Float?        // 0-100 confidence score
  aiSummary        String?       // AI analysis summary
  aiRawResponse    String?       // Full AI response JSON
  professionnelId  String
  professionnel    Professionnel @relation(fields: [professionnelId], references: [id])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model PasswordReset {
  id               String        @id @default(uuid())
  token            String        @unique
  expiresAt        DateTime
  used             Boolean       @default(false)
  usedAt           DateTime?
  ip               String?
  userAgent        String?
  professionnelId  String?
  professionnel    Professionnel? @relation(fields: [professionnelId], references: [id])
  athleteUserId    String?
  athleteUser      AthleteUser?  @relation(fields: [athleteUserId], references: [id])
  createdAt        DateTime      @default(now())
}

model SecurityAlert {
  id               String        @id @default(uuid())
  type             String        // password_reset_requested, password_changed, login_blocked, etc.
  message          String
  ip               String?
  userAgent        String?
  resolved         Boolean       @default(false)
  resolvedAt       DateTime?
  resolvedBy       String?       // admin who resolved it
  professionnelId  String
  professionnel    Professionnel @relation(fields: [professionnelId], references: [id])
  createdAt        DateTime      @default(now())
}

model AuthSession {
  id               String        @id @default(uuid())
  token            String        @unique           // Short-lived access token (15min)
  refreshToken     String?       @unique           // Long-lived refresh token (30d), rotated on each use
  expiresAt        DateTime                        // Access token expiry
  refreshExpiresAt DateTime?                       // Refresh token expiry
  tokenFamily      String?                         // Rotation chain ID — detects token reuse/theft
  rotationCount    Int           @default(0)       // How many times the refresh token was rotated
  lastActiveAt     DateTime      @default(now())
  revoked          Boolean       @default(false)
  revokedAt        DateTime?
  revokedReason    String?                         // "logout" | "rotation" | "theft_detected" | "expired" | "admin"
  ip               String?
  userAgent        String?
  deviceName       String?       // e.g. "Chrome on macOS"
  deviceHash       String?       // fingerprint to detect new devices
  professionnelId  String?
  professionnel    Professionnel? @relation(fields: [professionnelId], references: [id])
  athleteUserId    String?
  athleteUser      AthleteUser?   @relation(fields: [athleteUserId], references: [id])
  createdAt        DateTime      @default(now())
}

model Passkey {
  id               String        @id @default(uuid())
  credentialId     String        @unique
  publicKey        String        // base64-encoded public key
  counter          Int           @default(0)
  deviceType       String?       // singleDevice, multiDevice
  backedUp         Boolean       @default(false)
  transports       String[]      @default([]) // usb, ble, nfc, internal
  name             String?       // user-given name, e.g. "MacBook TouchID"
  professionnelId  String
  professionnel    Professionnel @relation(fields: [professionnelId], references: [id])
  lastUsedAt       DateTime?
  createdAt        DateTime      @default(now())
}

model Service {
  id               String        @id @default(uuid())
  nom              String
  personnalise     Boolean       @default(false)
  professionnelId  String
  professionnel    Professionnel @relation(fields: [professionnelId], references: [id], onDelete: Cascade)
}

model Tarif {
  id                  String        @id @default(uuid())
  label               String        // e.g. "Consultation", "Bilan initial", "Suivi"
  price               Int           // price in cents (e.g. 5000 = 50.00€)
  duration            Int           @default(30) // minutes
  description         String?
  format              String?       // "presentiel" | "teleconsultation" | null = both
  prestationType      String        @default("consultation_presentielle") // consultation_visio, consultation_presentielle, suivi_ponctuel, pack_non_remboursable
  remboursementLabel  String        @default("a_verifier_patient") // potentiellement_remboursable, hors_assurance_maladie, complementaire_possible, a_verifier_patient
  active              Boolean       @default(true)
  professionnelId     String
  professionnel       Professionnel @relation(fields: [professionnelId], references: [id], onDelete: Cascade)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([professionnelId])
}

model Disponibilite {
  id               String        @id @default(uuid())
  jourDebut        String
  jourFin          String
  heureDebut       String
  heureFin         String
  professionnelId  String
  professionnel    Professionnel @relation(fields: [professionnelId], references: [id], onDelete: Cascade)
}

model CalendrierSync {
  id               String        @id @default(uuid())
  type             String
  actif            Boolean       @default(false)
  accessToken      String?
  refreshToken     String?
  tokenExpiry      DateTime?
  email            String?
  professionnelId  String
  professionnel    Professionnel @relation(fields: [professionnelId], references: [id], onDelete: Cascade)

  @@unique([professionnelId, type])
}

enum RiskLevel {
  GOOD
  AVERAGE
  CRITICAL
}

enum Trend {
  IMPROVING
  STAGNATING
  DECLINING
}

enum AthleteStatus {
  active
  paused
  archived
}

model Athlete {
  id               String        @id @default(uuid())
  name             String
  sport            String?
  injuryNote       String?
  latestNote       String?
  lastContactAt    DateTime?
  riskLevel        RiskLevel     @default(GOOD)
  trend            Trend         @default(STAGNATING)
  status           AthleteStatus @default(active)

  // Page 1
  objectif         String?
  motif            String?
  contactEmail     String?
  contactPhone     String?
  consentement     Boolean       @default(false)
  consentementDate DateTime?
  consentementPartage     Boolean   @default(false)
  consentementPartageDate DateTime?

  // Page 2
  dateNaissance    DateTime?
  taille           Float?
  poids            Float?
  bodyZone         String?
  frequence        String?

  // Page 3
  antecedents      String[]      @default([])
  traitements      String?
  contreIndications String?
  dataTracking     String[]      @default([])
  canalCommunication String?

  // Lien vers le compte AthleteUser (optionnel, résolu via ConnectionRequest + email)
  athleteUserId    String?
  athleteUser      AthleteUser?  @relation(fields: [athleteUserId], references: [id], onDelete: SetNull)

  professionnelId  String
  professionnel    Professionnel @relation(fields: [professionnelId], references: [id], onDelete: Cascade)
  notes            AthleteNote[]
  calendarEvents   CalendarEvent[]
  kanbanTasks      KanbanTask[]    @relation("KanbanAthlete")
  sessions         Session[]
  proConnections   ProConnection[]
  proInvitations   ProInvitation[]
  collabNotes      CollabNote[]
  proMessages      ProMessage[]
  proConversations ProConversation[]
  invoices         Invoice[]
  kinePlans        KinePlan[]
  kineAlerts       KineAlert[]
  sharedDocs       SharedDocument[]
  sharedDocsCtx    SharedDocument[] @relation("DocAthleteContext")
  athleteDocsSent  AthleteDocument[] @relation("AthleteDocSender")
  athleteVideos    AthleteVideo[]
  nutriObjectives  NutriObjective[]
  nutriJournals    NutriJournal[]
  nutriMeasures    NutriMeasure[]
  nutriAlerts      NutriAlert[]
  nutriNotes       NutriConsultNote[]
  nutriPlans       NutriPlan[]
  medOrdonnances   MedOrdonnance[]
  medPrescriptions MedPrescription[]
  medProtocols     MedProtocol[]
  medAlerts        MedAlert[]
  medClinicalNotes MedClinicalNote[]
  medPlans         MedPlan[]
  medVitalEntries  MedVitalEntry[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  consentLogs      ConsentLog[]
  subjectRequests  SubjectAccessRequest[]

  // Soft-delete
  deletedAt        DateTime?
  deletedBy        String?

  @@index([athleteUserId])
}

// ─── Consentements côté athlète (RGPD) ───

model AthleteConsent {
  id              String        @id @default(uuid())
  athleteUserId   String
  athleteUser     AthleteUser   @relation(fields: [athleteUserId], references: [id], onDelete: Cascade)

  // Type: "cgu" | "privacy" | "health_data" | "pro_sharing" | "ai" | "marketing"
  consentType     String
  action          String        // "granted" | "revoked"
  granted         Boolean

  // What was accepted
  documentVersion String?       // e.g. "CGU-2026-04" or "PRIVACY-2026-04"
  documentUrl     String?       // URL to the document version

  // Context
  ip              String?
  userAgent       String?
  method          String        @default("digital") // "digital" | "checkbox"

  createdAt       DateTime      @default(now())

  @@index([athleteUserId, consentType])
  @@index([consentType, action])
}

// ─── Log d'accès côté athlète (RGPD traçabilité) ───

model AthleteAccessLog {
  id              String        @id @default(uuid())
  athleteUserId   String
  athleteUser     AthleteUser   @relation(fields: [athleteUserId], references: [id], onDelete: Cascade)
  action          String        // "view_profile" | "view_messages" | "view_documents" | "view_plans" | "view_ordonnances" | "view_vitals" | "export_data" | "update_profile" | "update_privacy" | "delete_document"
  resource        String?       // optional detail: e.g. "document:abc123" or "pro:xyz"
  ip              String?
  userAgent       String?
  createdAt       DateTime      @default(now())

  @@index([athleteUserId, createdAt])
}

// ─── Traçabilité des consentements (RGPD santé) ───

model ConsentLog {
  id              String        @id @default(uuid())

  // What consent was affected
  consentType     String        // "general" | "partage" | "export" | "data_processing"
  action          String        // "granted" | "revoked" | "renewed" | "updated"
  previousValue   Boolean?      // State before the change (null = first time)
  newValue        Boolean       // State after the change

  // How consent was collected
  method          String        @default("digital") // "verbal" | "written" | "digital" | "email"
  purpose         String?       // Free text: why consent was requested

  // Who
  athleteId       String
  athlete         Athlete       @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  actorProId      String        // The professional who recorded the consent
  actorPro        Professionnel @relation(fields: [actorProId], references: [id], onDelete: Cascade)

  // Context
  ip              String?
  userAgent       String?

  // Immutable timestamp
  createdAt       DateTime      @default(now())

  @@index([athleteId, consentType])
  @@index([actorProId])
}

model AthleteNote {
  id         String   @id @default(uuid())
  note       String
  athleteId  String
  athlete    Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model KanbanTask {
  id               String        @id @default(uuid())
  title            String
  description      String?
  column           String        @default("todo")
  position         Int           @default(0)
  priority         String        @default("medium")
  dueDate          DateTime?
  reminderMinutes  Int?
  reminderSeen     Boolean       @default(false)
  athleteId        String?
  athlete          Athlete?      @relation("KanbanAthlete", fields: [athleteId], references: [id], onDelete: SetNull)
  professionnelId  String
  professionnel    Professionnel @relation(fields: [professionnelId], references: [id], onDelete: Cascade)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Soft-delete
  deletedAt        DateTime?
  deletedBy        String?
}

model CalendarEvent {
  id               String        @id @default(uuid())
  title            String
  date             DateTime
  endDate          DateTime?
  allDay           Boolean       @default(false)
  type             String        @default("rdv")
  color            String        @default("orange")
  description      String?
  reminderMinutes  Int?
  reminderSeen     Boolean       @default(false)
  athleteId        String?
  athlete          Athlete?      @relation(fields: [athleteId], references: [id], onDelete: SetNull)
  athleteUserId    String?
  athleteUser      AthleteUser?  @relation(fields: [athleteUserId], references: [id], onDelete: SetNull)
  professionnelId  String
  professionnel    Professionnel @relation(fields: [professionnelId], references: [id], onDelete: Cascade)
